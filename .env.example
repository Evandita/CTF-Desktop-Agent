# LLM Provider: "claude", "ollama", or "claude-code"
#   claude      — Direct Anthropic API (requires ANTHROPIC_API_KEY)
#   ollama      — Local Ollama models (requires Ollama running)
#   claude-code — Uses Claude Code CLI as the brain (requires `claude` in PATH)
CTF_LLM_PROVIDER=claude

# Anthropic API key (required for "claude" provider)
ANTHROPIC_API_KEY=sk-ant-...

# Model override (optional)
# CTF_LLM_MODEL=claude-sonnet-4-20250514

# Ollama host (for "ollama" provider)
# CTF_OLLAMA_HOST=http://localhost:11434

# Container settings
# CTF_SCREEN_WIDTH=1024
# CTF_SCREEN_HEIGHT=768

# Agent settings
# CTF_MAX_ITERATIONS=50
# CTF_LOG_LEVEL=INFO
